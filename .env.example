# ----------------------------------------------------------------------------
# Foundry-Search-Cosmos demo — environment configuration
# Copy to .env and fill in your values:  Copy-Item .env.example .env
# ----------------------------------------------------------------------------

APP_ENV=dev

# --- Azure AI Foundry (agentic RAG host) ---
FOUNDRY_PROJECT_ENDPOINT=https://rag-ai-demo-resource.services.ai.azure.com/api/projects/rag-ai-demo
FOUNDRY_CHAT_MODEL=gpt-5-mini
# The hosted KB agent uses the Azure AI Search tool, which the gpt-5 family can't
# drive (gpt-5 supports only code interpreter + file search). Use a tool-compatible model.
FOUNDRY_KB_AGENT_MODEL=gpt-4.1-mini
FOUNDRY_EMBEDDING_MODEL=text-embedding-3-large
FOUNDRY_AGENT_NAME=insurance-rag-agent
KB_AGENT_NAME=kb-search-agent
ORCHESTRATOR_AGENT_NAME=orchestrator-agent
ORCHESTRATOR_AGENT_MODEL=gpt-4.1-mini
INSURANCE_ORCHESTRATOR_AGENT_NAME=insurance-orchestrator
INSURANCE_ORCHESTRATOR_AGENT_MODEL=gpt-4.1-mini
# Hosted policy agent (Cosmos DB via OpenAPI tool). POLICY_API_BASE_URL must be a
# public HTTPS URL the Foundry service can reach (dev tunnel or App Service).
POLICY_AGENT_NAME=policy-cosmos-agent
POLICY_AGENT_MODEL=gpt-4.1-mini
POLICY_API_BASE_URL=

# --- Azure AI Search (knowledge-base RAG) ---
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_INDEX=insurance-kb
# Leave the key empty to use Microsoft Entra ID (DefaultAzureCredential) — recommended.
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_SEMANTIC_CONFIG=insurance-kb-semantic
AZURE_SEARCH_VECTOR_FIELD=contentVector
AZURE_SEARCH_TOP_K=5
# Foundry project connection id to the Search service (for the hosted KB agent).
# Create it with scripts/deploy/create-search-connection.ps1
AZURE_SEARCH_CONNECTION_ID=

# --- Azure Blob Storage (KB source docs; Search indexer reads + vectorizes these) ---
# blob endpoint, e.g. https://<account>.blob.core.windows.net
AZURE_STORAGE_BLOB_ENDPOINT=
# full ARM resource id of the storage account (used for the keyless indexer data source)
AZURE_STORAGE_RESOURCE_ID=
AZURE_STORAGE_KB_CONTAINER=kb-docs

# --- Azure OpenAI / embeddings (used by integrated vectorization) ---
AZURE_OPENAI_ENDPOINT=https://rag-ai-demo-resource.cognitiveservices.azure.com
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIMENSIONS=3072

# --- Azure Cosmos DB (policy & claims RAG) ---
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
# Leave the key empty to use Microsoft Entra ID (DefaultAzureCredential) — recommended.
COSMOS_KEY=
COSMOS_DATABASE=insurance
COSMOS_POLICIES_CONTAINER=policies
COSMOS_CLAIMS_CONTAINER=claims
COSMOS_CUSTOMERS_CONTAINER=customers

# --- Knowledge-base source documents (for indexing) ---
KB_DOCS=data/auto_insurance_knowledge_base.docx,data/auto_insurance_glossary.md

# --- Observability (optional) ---
APPLICATIONINSIGHTS_CONNECTION_STRING=
OTEL_SERVICE_NAME=insurance-rag-api

HOSTED_KB_AGENT_NAME=kb-hosted-agent
HOSTED_POLICY_AGENT_NAME=policy-hosted-agent
